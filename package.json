{
  "name": "cetus-liquidity-rebalance-bot",
  "version": "1.0.0",
  "description": "Automatic liquidity rebalance bot for Cetus CLMM on Sui Network",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "cetus",
    "sui",
    "defi",
    "liquidity",
    "clmm",
    "rebalance",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cetusprotocol/cetus-sui-clmm-sdk": "^5.4.0",
    "@mysten/sui": "~1.21.1",
    "bn.js": "^5.2.1",
    "dotenv": "^16.4.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.33",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js", "json"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
    },
    "clearMocks": true
  },
  "overrides": {
    "@mysten/bcs": "~1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
