# ============================================================
# Cetus Liquidity Rebalance Bot — Environment Configuration
# ============================================================

# Network: mainnet or testnet
# Use "testnet" for dry-run / integration testing against the Cetus testnet.
NETWORK=mainnet

# Sui RPC endpoint (leave empty to use the default public endpoint)
# Default mainnet: https://fullnode.mainnet.sui.io:443
# Default testnet: https://fullnode.testnet.sui.io:443
SUI_RPC_URL=

# Wallet private key — KEEP THIS SECURE, never commit to git
# Must be exactly 64 hexadecimal characters (or 66 with 0x prefix)
PRIVATE_KEY=

# Pool address to manage (Cetus CLMM pool)
POOL_ADDRESS=

# How often to check positions (seconds) — default 60
CHECK_INTERVAL=60

# New position tick range (optional — derived from old position width if not set)
LOWER_TICK=
UPPER_TICK=

# New position range width in ticks (optional — used when LOWER_TICK/UPPER_TICK are not set;
# the range is centred on the current tick and aligned to tickSpacing).
# If neither RANGE_WIDTH nor LOWER_TICK/UPPER_TICK are set, defaults to ±10 tick spacings.
RANGE_WIDTH=

# Token amounts to use for ALL position operations (REQUIRED, in base units / MIST).
# These exact values are used for both new position creation and rebalancing.
# The bot NEVER derives amounts from wallet balance or previous positions.
# Example: 1 SUI = 1,000,000,000 MIST. Adjust for each token's decimals.
TOKEN_A_AMOUNT=
TOKEN_B_AMOUNT=

# Maximum slippage tolerance (e.g. 0.01 = 1%)
# Must be greater than 0 and less than 1 (i.e. between 0 % and 100 % exclusive).
# Values ≥ 1.0 are rejected at startup to prevent catastrophic losses on mainnet.
# Recommended: 0.005–0.02 for mainnet; up to 0.05 acceptable for testnet.
MAX_SLIPPAGE=0.01

# Gas budget per transaction in MIST (1 SUI = 1,000,000,000 MIST)
GAS_BUDGET=50000000

# Logging: debug | info | warn | error
LOG_LEVEL=info
VERBOSE_LOGS=false

# Dry-run mode — set to true to simulate without executing transactions
# Recommended for testnet smoke-tests: NETWORK=testnet DRY_RUN=true
DRY_RUN=false
